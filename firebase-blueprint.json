{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the platform (an analyst).",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "format": "uri" },
        "lastPostDate": { "type": "string", "format": "date-time" },
        "isPremium": { "type": "boolean", "description": "True if paying $100/m" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email", "isPremium", "role", "createdAt"]
    },
    "Idea": {
      "title": "Investment Idea",
      "description": "A fundamental analysis idea posted by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string", "format": "uri" },
        "title": { "type": "string" },
        "ticker": { "type": "string" },
        "content": { "type": "string" },
        "coverImage": { "type": "string", "format": "uri" },
        "votesCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "authorId", "authorName", "title", "ticker", "content", "votesCount", "createdAt", "updatedAt"]
    },
    "Vote": {
      "title": "Vote",
      "description": "A vote cast by a user on an idea.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "ideaId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "ideaId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and subscription status."
    },
    "/ideas/{ideaId}": {
      "schema": { "$ref": "#/entities/Idea" },
      "description": "Stores all investment ideas."
    },
    "/votes/{voteId}": {
      "schema": { "$ref": "#/entities/Vote" },
      "description": "Stores individual votes to prevent double voting."
    }
  }
}
